{
  "manifest_version": 3,
  "name": "One Piece Chapters Checker",
  "version": "1.0",
  "description": "View latest chapters from MangaDex",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.mangadex.org/*",
    "https://www.reddit.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "View latest chapters",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
